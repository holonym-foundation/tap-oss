      "verify": { "host": "api.stripe.com", "path": "/v1/balance", "ok": [200] }
    },
    {
      "id": "slack",
      "label": "Slack",
      "keys": [{ "pattern": "^SLACK_(BOT_|APP_|USER_)?TOKEN$" }],
      "value": "^xox[abpe]-",
      "hosts": ["slack.com"],
      "verify": {
        "host": "slack.com",
