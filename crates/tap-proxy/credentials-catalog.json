{
  "_comment": "Single source of truth for .env credential import + live verification. Consumed by the dashboard (Vite JSON import in dashboard/src/lib/envImport.js — recognition, auth shape, grouping) and by the proxy (include_str! in src/credential_verify.rs — verify probes). Same pattern as recipes.json. `keys[].pattern` / `value` are JavaScript regex source strings (may use lookahead; compiled only in JS — Rust never compiles them). `auth.scheme`: omitted/bearer = proxy default `Authorization: Bearer {value}`; header = auth_bindings into a custom header; raw = auth_header_format (optional `format`, default `{value}`); basic = HTTP Basic from username/password fields; aws = SigV4 bundle; manual = cannot be a plain direct credential (flagged in the importer, never auto-created). Multi-secret vendors list several `keys` entries with `field` (+ optional per-field `header`); `required` names the fields that must be present to recognize the vendor. `verify` is a curated, idempotent, quota-cheap probe whose HTTP status distinguishes good from bad auth; `verify.host` must be a concrete host from `hosts`. `okJsonField` handles APIs (Slack) that answer 200 either way and signal failure in the body — the proxy checks the field server-side and never returns the body. Omit `verify` when no such probe exists; the verify endpoint then falls back to a generic probe that can only definitively FAIL (401/403), never confirm.",
  "vendors": [
    {
      "id": "openai",
      "label": "OpenAI",
      "keys": [{ "pattern": "^OPENAI(_API)?_KEY$" }],
      "value": "^sk-(?!ant-|or-)",
      "hosts": ["api.openai.com"],
      "verify": { "host": "api.openai.com", "path": "/v1/models", "ok": [200] }
    },
    {
      "id": "anthropic",
      "label": "Anthropic",
      "keys": [{ "pattern": "^ANTHROPIC_API_KEY$" }],
      "value": "^sk-ant-",
      "auth": { "scheme": "header", "header": "x-api-key" },
      "hosts": ["api.anthropic.com"],
      "verify": {
        "host": "api.anthropic.com",
        "path": "/v1/models",
        "headers": { "anthropic-version": "2023-06-01" },
        "ok": [200]
      }
    },
    {
      "id": "openrouter",
      "label": "OpenRouter",
      "keys": [{ "pattern": "^OPENROUTER_API_KEY$" }],
      "value": "^sk-or-",
      "hosts": ["openrouter.ai"],
      "verify": { "host": "openrouter.ai", "path": "/api/v1/key", "ok": [200] }
    },
    {
      "id": "groq",
      "label": "Groq",
      "keys": [{ "pattern": "^GROQ_API_KEY$" }],
      "value": "^gsk_",
      "hosts": ["api.groq.com"],
      "verify": { "host": "api.groq.com", "path": "/openai/v1/models", "ok": [200] }
    },
    {
      "id": "gemini",
      "label": "Google AI (Gemini)",
      "keys": [{ "pattern": "^(GEMINI|GOOGLE_AI|GOOGLE_GENAI)_API_KEY$" }],
      "auth": { "scheme": "header", "header": "x-goog-api-key" },
      "hosts": ["generativelanguage.googleapis.com"],
      "verify": { "host": "generativelanguage.googleapis.com", "path": "/v1beta/models", "ok": [200] }
    },
    {
      "id": "mistral",
      "label": "Mistral",
      "keys": [{ "pattern": "^MISTRAL_API_KEY$" }],
      "hosts": ["api.mistral.ai"],
      "verify": { "host": "api.mistral.ai", "path": "/v1/models", "ok": [200] }
    },
    {
      "id": "cohere",
      "label": "Cohere",
      "keys": [{ "pattern": "^COHERE_API_KEY$" }],
      "hosts": ["api.cohere.com"],
      "verify": { "host": "api.cohere.com", "path": "/v1/models", "ok": [200] }
    },
    {
      "id": "github",
      "label": "GitHub",
      "keys": [{ "pattern": "^(GITHUB_TOKEN|GH_TOKEN|GITHUB_PAT)$" }],
      "value": "^(ghp_|github_pat_|gho_)",
      "hosts": ["api.github.com"],
      "verify": { "host": "api.github.com", "path": "/rate_limit", "ok": [200] }
    },
    {
      "id": "stripe",
      "label": "Stripe",
      "keys": [{ "pattern": "^STRIPE_(SECRET_KEY|API_KEY|KEY)$" }],
      "value": "^[sr]k_(live|test)_",
